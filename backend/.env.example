# Database
DATABASE_URL=postgresql://vibehealth:vibehealth_dev@localhost:5432/vibehealth

# Server
PORT=3000
NODE_ENV=development

# Auth (BetterAuth)
AUTH_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_IN_PRODUCTION
AUTH_URL=http://localhost:3000

# Frontend
FRONTEND_URL=http://localhost:4200

# OAuth Providers (optional - leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Notifications (to be configured in later phases)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# FCM_SERVER_KEY=

# Email delivery (useSend)
USESEND_API_KEY=
USESEND_FROM_EMAIL=
USESEND_BASE_URL=https://app.usesend.com/api

# External APIs (to be configured in later phases)
# OPENFDA_API_KEY=
# OPENSTREETMAP_API_KEY=

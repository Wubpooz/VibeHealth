// VibeHealth Database Schema
// Phase 0 — Foundation Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User and Authentication
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  password      String?
  name          String?
  image         String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  profile   Profile?
  medicalId MedicalId?
  sessions  Session[]
  accounts  Account[]

  @@map("users")
}

enum Role {
  USER
  CAREGIVER
  ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Profile (from onboarding)
model Profile {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  dateOfBirth             DateTime?
  biologicalSex           String?
  height                  Float?
  weight                  Float?
  fitnessLevel            String?
  goals                   String[]
  medicalConditions       String[]
  allergies               String[]
  currentMedications      String[]
  notificationPreferences Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// Medical ID (Phase 0.5)
model MedicalId {
  id                String   @id @default(cuid())
  userId            String   @unique
  bloodType         String?
  allergies         String[]
  medications       String[]
  emergencyContacts Json[]
  qrCode            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_ids")
}

// Verification tokens (for email verification, magic links, password reset)
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// Vitals Log (heart rate, blood pressure, sleep, steps, weight)
model VitalLog {
  id        String    @id @default(cuid())
  userId    String
  type      VitalType
  value     Float
  unit      String
  source    String?   @default("manual") // manual, apple_health, google_fit
  notes     String?
  loggedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, type, loggedAt])
  @@map("vital_logs")
}

enum VitalType {
  HEART_RATE
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  SLEEP_HOURS
  STEPS
  WEIGHT
  BODY_TEMPERATURE
  OXYGEN_SATURATION
}

// Hydration Log (water intake tracking)
model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Float // in ml
  unit      String   @default("ml") // ml or oz
  source    String?  @default("manual")
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, loggedAt])
  @@map("hydration_logs")
}

// Activity Log (exercise and movement tracking)
model ActivityLog {
  id           String       @id @default(cuid())
  userId       String
  type         ActivityType
  name         String // e.g., "Morning Run", "Gym Session"
  duration     Int // in minutes
  calories     Int? // estimated calories burned
  distance     Float? // in km (for runs, walks, cycling)
  intensity    Intensity    @default(MODERATE)
  heartRateAvg Int? // average heart rate during activity
  notes        String?
  source       String?      @default("manual") // manual, google_fit, apple_health
  loggedAt     DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, type, loggedAt])
  @@map("activity_logs")
}

enum ActivityType {
  WALK
  RUN
  CYCLE
  SWIM
  YOGA
  STRENGTH
  HIIT
  SPORTS
  DANCE
  OTHER
}

enum Intensity {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

// Meal Log (food and nutrition tracking)
model MealLog {
  id          String   @id @default(cuid())
  userId      String
  mealType    MealType
  name        String // e.g., "Chicken Salad", "Oatmeal Breakfast"
  calories    Int?
  protein     Float? // grams
  carbs       Float? // grams
  fat         Float? // grams
  fiber       Float? // grams
  sugar       Float? // grams
  sodium      Float? // mg
  servingSize String? // e.g., "1 cup", "200g"
  barcode     String? // for scanned products
  notes       String?
  imageUrl    String? // photo of meal
  source      String?  @default("manual") // manual, barcode_scan, photo_ai
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, mealType, loggedAt])
  @@map("meal_logs")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

// Goal tracking (SMART goals)
model Goal {
  id          String    @id @default(cuid())
  userId      String
  type        GoalType
  title       String
  description String?
  targetValue Float // e.g., 10000 steps, 2.5L water
  targetUnit  String // e.g., "steps", "ml", "minutes"
  frequency   GoalFreq  @default(DAILY)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  progress GoalProgress[]

  @@index([userId, type, isActive])
  @@map("goals")
}

enum GoalType {
  STEPS
  HYDRATION
  CALORIES_IN
  CALORIES_OUT
  SLEEP
  ACTIVITY_MINUTES
  WEIGHT
  CUSTOM
}

enum GoalFreq {
  DAILY
  WEEKLY
  MONTHLY
}

// Goal Progress tracking
model GoalProgress {
  id        String   @id @default(cuid())
  goalId    String
  date      DateTime @default(now()) // Date for this progress entry
  value     Float // Progress value for this period
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([goalId, date])
  @@map("goal_progress")
}

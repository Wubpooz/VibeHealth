// VibeHealth Database Schema
// Phase 0 — Foundation Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User and Authentication
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  password      String?
  name          String?
  image         String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  profile   Profile?
  medicalId MedicalId?
  workoutPlans WorkoutPlan[]
  healthSyncConnections HealthSyncConnection[]
  sessions  Session[]
  accounts  Account[]

  @@map("users")
}

enum Role {
  USER
  CAREGIVER
  ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Profile (from onboarding)
model Profile {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  dateOfBirth             DateTime?
  biologicalSex           String?
  height                  Float?
  weight                  Float?
  fitnessLevel            String?
  preferredActivityKey    String?
  goals                   String[]
  medicalConditions       String[]
  allergies               String[]
  currentMedications      String[]
  notificationPreferences Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Medication management (new model relation)
  medicationEntries Medication[]

  @@map("profiles")
}

enum ReminderRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  ONE_TIME
}

model Medication {
  id           String              @id @default(cuid())
  profileId    String
  name         String
  standardName String?             // Optional universal drug name (WHO INN, etc.)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt

  profile   Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reminders MedicationReminder[]

  @@index([profileId])
  @@map("medications")
}

model MedicationReminder {
  id            String            @id @default(cuid())
  medicationId  String
  timeOfDay     String            // e.g. "08:00" or "20:30"
  dosage        String
  recurrence    ReminderRecurrence
  nextDueAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt

  medication   Medication         @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
  @@map("medication_reminders")
}

// Medical ID (Phase 0.5)
model MedicalId {
  id                String   @id @default(cuid())
  userId            String   @unique
  bloodType         String?
  allergies         String[]
  medications       String[]
  emergencyContacts Json[]
  qrCode            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_ids")
}

// Verification tokens (for email verification, magic links, password reset)
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// Vitals Log (heart rate, blood pressure, sleep, steps, weight)
model VitalLog {
  id        String    @id @default(cuid())
  userId    String
  type      VitalType
  value     Float
  unit      String
  source    String?   @default("manual") // manual, apple_health, google_fit
  notes     String?
  loggedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, type, loggedAt])
  @@map("vital_logs")
}

enum VitalType {
  HEART_RATE
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  SLEEP_HOURS
  STEPS
  WEIGHT
  BODY_TEMPERATURE
  OXYGEN_SATURATION
}

// Hydration Log (water intake tracking)
model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Float // in ml
  unit      String   @default("ml") // ml or oz
  source    String?  @default("manual")
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, loggedAt])
  @@map("hydration_logs")
}

// Activity Catalog (reference table — seeded, rarely changes)
model ActivityCatalog {
  id          String       @id @default(cuid())
  key         String       @unique // e.g. "RUN_5MPH", "YOGA_VINYASA"
  name        String // Human-readable name
  category    ActivityType // Maps to the enum for grouping
  metValue    Float // MET = Metabolic Equivalent of Task (from Compendium of Physical Activities)
  emoji       String
  description String?
  tags        String[] // e.g. ["cardio", "outdoor", "high-impact"]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  activityLogs ActivityLog[]

  @@index([category])
  @@map("activity_catalog")
}

// Activity Log (exercise and movement tracking)
model ActivityLog {
  id                String           @id @default(cuid())
  userId            String
  type              ActivityType
  name              String // e.g., "Morning Run", "Gym Session"
  duration          Int // in minutes
  calories          Int? // estimated calories burned (MET × weight_kg × hours)
  distance          Float? // in km (for runs, walks, cycling)
  intensity         Intensity        @default(MODERATE)
  heartRateAvg      Int? // average heart rate during activity
  notes             String?
  source            String?          @default("manual") // manual, google_fit, apple_health, timer
  metValue          Float? // MET value used for calorie calculation
  activityCatalogId String? // FK to ActivityCatalog (optional — allows free-text too)
  loggedAt          DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  activityCatalog ActivityCatalog? @relation(fields: [activityCatalogId], references: [id])

  @@index([userId, type, loggedAt])
  @@map("activity_logs")
}

enum ActivityType {
  WALK
  RUN
  CYCLE
  SWIM
  YOGA
  STRENGTH
  HIIT
  SPORTS
  DANCE
  OTHER
  // Extended categories
  ROWING
  CLIMB
  MARTIAL_ARTS
  WINTER_SPORTS
  WATER_SPORTS
  RACKET_SPORTS
  TEAM_SPORTS
  MINDFULNESS
}

enum Intensity {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

// Meal Log (food and nutrition tracking)
model MealLog {
  id          String   @id @default(cuid())
  userId      String
  mealType    MealType
  name        String // e.g., "Chicken Salad", "Oatmeal Breakfast"
  calories    Int?
  protein     Float? // grams
  carbs       Float? // grams
  fat         Float? // grams
  fiber       Float? // grams
  sugar       Float? // grams
  sodium      Float? // mg
  servingSize String? // e.g., "1 cup", "200g"
  barcode     String? // for scanned products
  notes       String?
  imageUrl    String? // photo of meal
  source      String?  @default("manual") // manual, barcode_scan, photo_ai
  mealCatalogId String?
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mealCatalog MealCatalog? @relation(fields: [mealCatalogId], references: [id])

  @@index([userId, mealType, loggedAt])
  @@map("meal_logs")
}

// Meal Catalog (reference table — seeded, rarely changes)
model MealCatalog {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "BREAKFAST_OATMEAL", "LUNCH_GREEK_BOWL"
  mealType    MealType
  name        String
  calories    Int
  protein     Float? // grams
  carbs       Float? // grams
  fat         Float? // grams
  fiber       Float? // grams
  sugar       Float? // grams
  sodium      Float? // mg
  servingSize String? // e.g. "1 bowl", "200g"
  emoji       String
  tags        String[] // e.g. ["high-protein", "vegetarian", "quick"]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mealLogs MealLog[]

  @@index([mealType])
  @@map("meal_catalog")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

// Goal tracking (SMART goals)
model Goal {
  id          String    @id @default(cuid())
  userId      String
  type        GoalType
  title       String
  description String?
  targetValue Float // e.g., 10000 steps, 2.5L water
  targetUnit  String // e.g., "steps", "ml", "minutes"
  frequency   GoalFreq  @default(DAILY)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  progress GoalProgress[]

  @@index([userId, type, isActive])
  @@map("goals")
}

enum GoalType {
  STEPS
  HYDRATION
  CALORIES_IN
  CALORIES_OUT
  SLEEP
  ACTIVITY_MINUTES
  WEIGHT
  CUSTOM
}

enum GoalFreq {
  DAILY
  WEEKLY
  MONTHLY
}

// Goal Progress tracking
model GoalProgress {
  id        String   @id @default(cuid())
  goalId    String
  date      DateTime @default(now()) // Date for this progress entry
  value     Float // Progress value for this period
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([goalId, date])
  @@map("goal_progress")
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  MOBILITY
  FLEXIBILITY
  RECOVERY
}

enum WorkoutDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum HealthSyncProvider {
  GOOGLE_FIT
  SAMSUNG_HEALTH
}

model ExerciseCatalog {
  id                 String             @id @default(cuid())
  key                String             @unique
  name               String
  category           ExerciseCategory
  difficulty         WorkoutDifficulty
  defaultSets        Int                @default(3)
  defaultRepsMin     Int                @default(8)
  defaultRepsMax     Int                @default(12)
  defaultRestSeconds Int                @default(60)
  instructions       String?
  tags               String[]
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workoutExercises WorkoutPlanExercise[]

  @@index([category, difficulty])
  @@map("exercise_catalog")
}

model WorkoutPlan {
  id          String             @id @default(cuid())
  userId      String
  name        String
  description String?
  difficulty  WorkoutDifficulty
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutPlanExercise[]

  @@index([userId, isActive])
  @@map("workout_plans")
}

model WorkoutPlanExercise {
  id               String      @id @default(cuid())
  workoutPlanId    String
  exerciseCatalogId String
  orderIndex       Int
  sets             Int
  repsMin          Int
  repsMax          Int
  restSeconds      Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  workoutPlan WorkoutPlan   @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise    ExerciseCatalog @relation(fields: [exerciseCatalogId], references: [id])

  @@unique([workoutPlanId, orderIndex])
  @@index([exerciseCatalogId])
  @@map("workout_plan_exercises")
}

model HealthSyncConnection {
  id          String             @id @default(cuid())
  userId      String
  provider    HealthSyncProvider
  connected   Boolean            @default(false)
  autoSync    Boolean            @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("health_sync_connections")
}

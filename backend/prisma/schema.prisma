// VibeHealth Database Schema
// Phase 0 — Foundation Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User and Authentication
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  password      String?
  name          String?
  image         String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  profile   Profile?
  medicalId MedicalId?
  workoutPlans WorkoutPlan[]
  healthSyncConnections HealthSyncConnection[]
  sessions  Session[]
  accounts  Account[]

  @@map("users")
}

enum Role {
  USER
  CAREGIVER
  ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Profile (from onboarding)
model Profile {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  dateOfBirth             DateTime?
  biologicalSex           String?
  height                  Float?
  weight                  Float?
  fitnessLevel            String?
  preferredActivityKey    String?
  preferredCountryCode    String?
  goals                   String[]
  medicalConditions       String[]
  allergies               String[]
  currentMedications      String[]
  notificationPreferences Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Medication management (new model relation)
  medicationEntries Medication[]

  @@map("profiles")
}

enum ReminderRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  ONE_TIME
}

model Medication {
  id           String              @id @default(cuid())
  profileId    String
  name         String
  standardName String?             // Optional universal drug name (WHO INN, etc.)
  notes        String?
  duration     Int?                // Duration in days (for refill alerts)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt

  profile   Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reminders MedicationReminder[]

  @@index([profileId])
  @@map("medications")
}

model MedicationReminder {
  id            String            @id @default(cuid())
  medicationId  String
  timeOfDay     String            // e.g. "08:00" or "20:30"
  dosage        String
  recurrence    ReminderRecurrence
  dayOfWeek     Int?              // 1=Monday..7=Sunday for WEEKLY recurrence
  dayOfMonth    Int?              // 1..31 for MONTHLY recurrence
  date          DateTime?         // exact date for ONE_TIME recurrence
  nextDueAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt

  medication   Medication         @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
  @@map("medication_reminders")
}

// Medical ID (Phase 0.5)
model MedicalId {
  id                String   @id @default(cuid())
  userId            String   @unique
  bloodType         String?
  allergies         String[]
  medications       String[]
  emergencyContacts Json[]
  qrCode            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_ids")
}

// Verification tokens (for email verification, magic links, password reset)
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// Vitals Log (heart rate, blood pressure, sleep, steps, weight)
model VitalLog {
  id        String    @id @default(cuid())
  userId    String
  type      VitalType
  value     Float
  unit      String
  source    String?   @default("manual") // manual, apple_health, google_fit
  notes     String?
  loggedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, type, loggedAt])
  @@map("vital_logs")
}

enum VitalType {
  HEART_RATE
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  SLEEP_HOURS
  STEPS
  WEIGHT
  BODY_TEMPERATURE
  OXYGEN_SATURATION
}

// Hydration Log (water intake tracking)
model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Float // in ml
  unit      String   @default("ml") // ml or oz
  source    String?  @default("manual")
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, loggedAt])
  @@map("hydration_logs")
}

// Activity Catalog (reference table — seeded, rarely changes)
model ActivityCatalog {
  id          String       @id @default(cuid())
  key         String       @unique // e.g. "RUN_5MPH", "YOGA_VINYASA"
  name        String // Human-readable name
  category    ActivityType // Maps to the enum for grouping
  metValue    Float // MET = Metabolic Equivalent of Task (from Compendium of Physical Activities)
  emoji       String
  description String?
  tags        String[] // e.g. ["cardio", "outdoor", "high-impact"]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  activityLogs ActivityLog[]

  @@index([category])
  @@map("activity_catalog")
}

// Activity Log (exercise and movement tracking)
model ActivityLog {
  id                String           @id @default(cuid())
  userId            String
  type              ActivityType
  name              String // e.g., "Morning Run", "Gym Session"
  duration          Int // in minutes
  calories          Int? // estimated calories burned (MET × weight_kg × hours)
  distance          Float? // in km (for runs, walks, cycling)
  intensity         Intensity        @default(MODERATE)
  heartRateAvg      Int? // average heart rate during activity
  notes             String?
  source            String?          @default("manual") // manual, google_fit, apple_health, timer
  metValue          Float? // MET value used for calorie calculation
  activityCatalogId String? // FK to ActivityCatalog (optional — allows free-text too)
  loggedAt          DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  activityCatalog ActivityCatalog? @relation(fields: [activityCatalogId], references: [id])

  @@index([userId, type, loggedAt])
  @@map("activity_logs")
}

enum ActivityType {
  WALK
  RUN
  CYCLE
  SWIM
  YOGA
  STRENGTH
  HIIT
  SPORTS
  DANCE
  OTHER
  // Extended categories
  ROWING
  CLIMB
  MARTIAL_ARTS
  WINTER_SPORTS
  WATER_SPORTS
  RACKET_SPORTS
  TEAM_SPORTS
  MINDFULNESS
}

enum Intensity {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

// Meal Log (food and nutrition tracking)
model MealLog {
  id          String   @id @default(cuid())
  userId      String
  mealType    MealType
  name        String // e.g., "Chicken Salad", "Oatmeal Breakfast"
  calories    Int?
  protein     Float? // grams
  carbs       Float? // grams
  fat         Float? // grams
  fiber       Float? // grams
  sugar       Float? // grams
  sodium      Float? // mg
  servingSize String? // e.g., "1 cup", "200g"
  barcode     String? // for scanned products
  notes       String?
  imageUrl    String? // photo of meal
  source      String?  @default("manual") // manual, barcode_scan, photo_ai
  mealCatalogId String?
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mealCatalog MealCatalog? @relation(fields: [mealCatalogId], references: [id])

  @@index([userId, mealType, loggedAt])
  @@map("meal_logs")
}

// Meal Catalog (reference table — seeded, rarely changes)
model MealCatalog {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "BREAKFAST_OATMEAL", "LUNCH_GREEK_BOWL"
  mealType    MealType
  name        String
  calories    Int
  protein     Float? // grams
  carbs       Float? // grams
  fat         Float? // grams
  fiber       Float? // grams
  sugar       Float? // grams
  sodium      Float? // mg
  servingSize String? // e.g. "1 bowl", "200g"
  emoji       String
  tags        String[] // e.g. ["high-protein", "vegetarian", "quick"]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mealLogs MealLog[]

  @@index([mealType])
  @@map("meal_catalog")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

// Goal tracking (SMART goals)
model Goal {
  id          String    @id @default(cuid())
  userId      String
  type        GoalType
  title       String
  description String?
  targetValue Float // e.g., 10000 steps, 2.5L water
  targetUnit  String // e.g., "steps", "ml", "minutes"
  frequency   GoalFreq  @default(DAILY)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  progress GoalProgress[]

  @@index([userId, type, isActive])
  @@map("goals")
}

enum GoalType {
  STEPS
  HYDRATION
  CALORIES_IN
  CALORIES_OUT
  SLEEP
  ACTIVITY_MINUTES
  WEIGHT
  CUSTOM
}

enum GoalFreq {
  DAILY
  WEEKLY
  MONTHLY
}

// Goal Progress tracking
model GoalProgress {
  id        String   @id @default(cuid())
  goalId    String
  date      DateTime @default(now()) // Date for this progress entry
  value     Float // Progress value for this period
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([goalId, date])
  @@map("goal_progress")
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  MOBILITY
  FLEXIBILITY
  RECOVERY
}

enum WorkoutDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum HealthSyncProvider {
  GOOGLE_FIT
  SAMSUNG_HEALTH
}

model ExerciseCatalog {
  id                 String             @id @default(cuid())
  key                String             @unique
  name               String
  category           ExerciseCategory
  difficulty         WorkoutDifficulty
  defaultSets        Int                @default(3)
  defaultRepsMin     Int                @default(8)
  defaultRepsMax     Int                @default(12)
  defaultRestSeconds Int                @default(60)
  instructions       String?
  tags               String[]
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workoutExercises WorkoutPlanExercise[]

  @@index([category, difficulty])
  @@map("exercise_catalog")
}

model WorkoutPlan {
  id          String             @id @default(cuid())
  userId      String
  name        String
  description String?
  difficulty  WorkoutDifficulty
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutPlanExercise[]

  @@index([userId, isActive])
  @@map("workout_plans")
}

model WorkoutPlanExercise {
  id               String      @id @default(cuid())
  workoutPlanId    String
  exerciseCatalogId String
  orderIndex       Int
  sets             Int
  repsMin          Int
  repsMax          Int
  restSeconds      Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  workoutPlan WorkoutPlan   @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise    ExerciseCatalog @relation(fields: [exerciseCatalogId], references: [id])

  @@unique([workoutPlanId, orderIndex])
  @@index([exerciseCatalogId])
  @@map("workout_plan_exercises")
}

model HealthSyncConnection {
  id          String             @id @default(cuid())
  userId      String
  provider    HealthSyncProvider
  connected   Boolean            @default(false)
  autoSync    Boolean            @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("health_sync_connections")
}

// Mood Log (daily mood tracking — Phase 1.5 Wellness)
model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // Date of mood entry (stored as date, without time)
  mood      MoodEmoji // 6-emoji mood scale
  note      String? // Optional free-text mood note
  tags      String[] // Mood tags (e.g., ["stressed", "energetic", "anxious"])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journalEntries JournalEntry[]

  @@unique([userId, date])
  @@index([userId, date])
  @@index([userId, createdAt])
  @@map("mood_logs")
}

enum MoodEmoji {
  VERY_SAD // 😢
  SAD // 😕
  NEUTRAL // 😐
  HAPPY // 🙂
  VERY_HAPPY // 😄
  EXCITED // 🤩
}

// Journal Entry (journaling with rich text and media)
model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  title       String? // Optional title
  richText    String // Rich text content (HTML or Markdown)
  moodLogId   String? // Optional reference to mood entry
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  moodLog          MoodLog?           @relation(fields: [moodLogId], references: [id], onDelete: SetNull)
  mediaAttachments MediaAttachment[]

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@map("journal_entries")
}

// Media Attachment (images and audio for journal entries)
model MediaAttachment {
  id               String    @id @default(cuid())
  journalEntryId   String
  type             MediaType // IMAGE or AUDIO
  url              String // URL to media file (S3, CDN, etc.)
  mimeType         String // e.g., "image/jpeg", "audio/mp3"
  durationSeconds  Int? // Duration in seconds (for audio only)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@map("media_attachments")
}

enum MediaType {
  IMAGE
  AUDIO
}

// ======== REFERENCE DATA MODELS (Phase 1+) ========

// First Aid Categories (with locale translations)
model FirstAidCategory {
  id        String   @id @default(cuid())
  key       String // e.g., "CPR", "BURNS"
  locale    String   @default("en") // en, fr, etc.
  name      String
  icon      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards FirstAidCard[]

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("first_aid_categories")
}

// First Aid Cards (with locale-specific content)
model FirstAidCard {
  id                    String   @id @default(cuid())
  key                   String // e.g., "cpr-adult"
  locale                String   @default("en")
  categoryId            String
  titleKey              String // i18n key for title
  descriptionKey        String // i18n key for description
  icon                  String
  severity              String // critical, serious, moderate, minor
  stepsJson             String // JSON array of step objects with i18n keys
  warningsJson          String // JSON array of warning i18n keys
  doNotJson             String // JSON array of do-not i18n keys
  whenToCallEmergencyJson String // JSON array of emergency call i18n keys
  relatedCardsJson      String? // JSON array of related card keys
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  category FirstAidCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([key, locale])
  @@index([locale, severity, isActive])
  @@index([categoryId])
  @@map("first_aid_cards")
}

// Emergency Numbers (with locale)
model EmergencyNumber {
  id          String   @id @default(cuid())
  countryCode String // e.g., "US", "FR", "GB"
  locale      String   @default("en")
  category    String // AMBULANCE, POLICE, POISON, MENTAL_HEALTH, etc.
  number      String
  description String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([countryCode, category, locale])
  @@index([countryCode, locale])
  @@map("emergency_numbers")
}

// Helplines (mental health, crisis, etc. with locale)
model Helpline {
  id          String   @id @default(cuid())
  countryCode String // e.g., "US", "FR", "GB", "INT" for international
  locale      String   @default("en")
  name        String
  category    String // SUICIDE, DOMESTIC_VIOLENCE, ADDICTION, MENTAL_HEALTH, etc.
  number      String?
  email       String?
  url         String?
  description String?
  hoursOperating String? // e.g., "24/7" or "Mon-Fri 9-5"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([countryCode, category, locale])
  @@index([countryCode, locale])
  @@map("helplines")
}

// Wiki Conditions (medical encyclopedia entries with locale)
model WikiCondition {
  id        String   @id @default(cuid())
  key       String // e.g., "hypertension"
  locale    String   @default("en")
  title     String
  subtitle  String
  summary   String
  sourceUrl String
  sourceName String
  tagsJson  String // JSON array of tags
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("wiki_conditions")
}

// Onboarding Reference Data (goals, fitness levels, conditions, allergies)
model OnboardingGoal {
  id          String   @id @default(cuid())
  key         String // e.g., "weight_loss", "stress_reduction"
  locale      String   @default("en")
  label       String
  emoji       String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("onboarding_goals")
}

model OnboardingFitnessLevel {
  id          String   @id @default(cuid())
  key         String // e.g., "sedentary", "very_active"
  locale      String   @default("en")
  label       String
  description String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("onboarding_fitness_levels")
}

model OnboardingCondition {
  id        String   @id @default(cuid())
  key       String // e.g., "diabetes", "hypertension"
  locale    String   @default("en")
  name      String
  category  String? // Optional category
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("onboarding_conditions")
}

model OnboardingAllergy {
  id        String   @id @default(cuid())
  key       String // e.g., "peanuts", "latex"
  locale    String   @default("en")
  name      String
  category  String? // Optional category: FOOD, DRUG, ENVIRONMENTAL
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("onboarding_allergies")
}

model OnboardingMedication {
  id        String   @id @default(cuid())
  key       String // e.g., "metformin", "acetaminophen"
  locale    String   @default("en")
  name      String
  category  String? // Optional category: ANALGESIC, ANTIBIOTIC, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale, isActive])
  @@map("onboarding_medications")
}

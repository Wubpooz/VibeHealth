{
  "name": "vibehealth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "cd backend && bun run dev",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:stack": "concurrently \"bun run dev:backend_stack\" \"bun run dev:frontend\"",
    "dev:backend_stack": "cd backend && bun run dev:stack",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd backend && bun run build",
    "build:frontend": "cd frontend && bun run build",
    "test": "bun run test:backend && bun run test:frontend",
    "test:backend": "cd backend && bun test",
    "test:frontend": "cd frontend && bun run test",
    "lint:frontend": "cd frontend && bun run lint",
    "watch:frontend": "cd frontend && bun run watch",
    "ng:frontend": "cd frontend && bun run ng",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:studio": "cd backend && bun run db:studio",
    "dev:stack-dockerless": "cd backend && DATABASE_URL=postgresql://vibehealth:vibehealth_dev@localhost:5432/vibehealth bun run db:generate && bun run db:push && bun run db:seed && bun run dev"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^8.2.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "n": "^10.2.0",
    "ng-animated-icons": "^1.9.0"
  }
}
